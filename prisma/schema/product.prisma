model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String   @id @default(cuid())
  badge            String?  // e.g., "New", "Bestseller", "Clinically Studied"
  title            String
  slug             String   @unique
  description      String   @db.Text
  shortDescription String?  @db.Text

  price          Decimal @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  stock          Int     @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  thumbnailImage String
  thumbnailVideo String?
  images         ProductImage[]

  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  benefits            ProductBenefit[]
  ingredients         Ingredient[]
  timeBasedBenefits   TimeBasedBenefit[]
  additionalDescriptions AdditionalDescription[]
  howToUse            String? @db.Text
  comparisonTable     ProductComparison?

  reviews Review[]

  cartItems  CartItem[]
  orderItems OrderItem[]
  offers     ProductOffer[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
}

model ProductImage {
  id    String @id @default(cuid())
  url   String
  alt   String?
  order Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductBenefit {
  id          String @id @default(cuid())
  title       String
  description String @db.Text
  icon        String?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id                 String @id @default(cuid())
  name               String
  description        String @db.Text
  molecularImage     String?
  activationTimeline String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model TimeBasedBenefit {
  id          String @id @default(cuid())
  weekLabel   String
  title       String
  description String @db.Text
  order       Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, order])
}

model AdditionalDescription {
  id          String @id @default(cuid())
  icon        String
  title       String?
  description String @db.Text

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductComparison {
  id          String                    @id @default(cuid())
  productId   String                    @unique
  product     Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  competitors ProductComparisonCompetitor[]
  features    ProductComparisonFeature[]
}

model ProductComparisonCompetitor {
  id        String @id @default(cuid())
  name      String
  logo      String?
  order     Int    @default(0)

  comparisonId String
  comparison   ProductComparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  values ProductComparisonValue[]
}

model ProductComparisonFeature {
  id   String @id @default(cuid())
  name String
  order Int   @default(0)

  comparisonId String
  comparison   ProductComparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  values ProductComparisonValue[]
}

model ProductComparisonValue {
  id         String @id @default(cuid())
  hasFeature Boolean @default(false)

  featureId String
  feature   ProductComparisonFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  competitorId String
  competitor   ProductComparisonCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([featureId, competitorId])
}

model Review {
  id           String @id @default(cuid())
  rating       Int
  title        String?
  content      String @db.Text
  authorName   String
  authorEmail  String?
  isVerified   Boolean @default(false)
  helpfulCount Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, createdAt])
}
